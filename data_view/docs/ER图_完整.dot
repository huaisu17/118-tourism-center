digraph ER {
    graph [fontname="Microsoft YaHei", fontsize=12, rankdir=TB,
           bgcolor=white, margin=0, nodesep=0.35, ranksep=0.9];
    node [fontname="Microsoft YaHei", fontsize=10,
          shape=rectangle, style=filled, fillcolor="#f8f9fa",
          width=0, height=0, margin="0.15,0.08"];
    edge [fontname="Microsoft YaHei", fontsize=9,
          arrowhead=none, color="#333333"];

    /* ============================================================
       实体
       ============================================================ */
    { rank=same;
      Canteen [label="食堂"];
      Supplier [label="供应商"];
      IngCat [label="食材分类"];
    }

    Ingredient [label="食材"];

    { rank=same;
      Purchase [label="采购订单"];
      PurItem [label="采购明细"];
    }

    IngAccept [label="食材验收"];

    /* ============================================================
       关系与关系属性
       ============================================================ */

    /* 食材分类 ——分类——> 食材 */
    R1 [shape=diamond, label="分类", fillcolor="#e3f2fd"];
    IngCat -> R1 [label="1", len=0.3];
    R1 -> Ingredient [label="n", len=0.3];

    /* 食堂 ——采购——> 采购订单 */
    R2 [shape=diamond, label="采购", fillcolor="#e3f2fd"];
    r2_date [shape=ellipse, label="采购日期", style=dashed, fillcolor=white];
    Canteen -> R2 [label="1", len=0.3];
    R2 -> Purchase [label="n", len=0.3];
    R2 -> r2_date [style=dashed, len=0.15];

    /* 供应商 ——供货——> 采购订单 */
    R3 [shape=diamond, label="供货", fillcolor="#e3f2fd"];
    r3_date [shape=ellipse, label="供货日期", style=dashed, fillcolor=white];
    Supplier -> R3 [label="1", len=0.3];
    R3 -> Purchase [label="n", len=0.3];
    R3 -> r3_date [style=dashed, len=0.15];

    /* 采购订单 ——包含——> 采购明细 */
    R4 [shape=diamond, label="包含", fillcolor="#e3f2fd"];
    r4_no [shape=ellipse, label="行号", style=dashed, fillcolor=white];
    Purchase -> R4 [label="1", len=0.3];
    R4 -> PurItem [label="n", len=0.3];
    R4 -> r4_no [style=dashed, len=0.15];

    /* 食材 ——被采购——> 采购明细 */
    R5 [shape=diamond, label="被采购", fillcolor="#e3f2fd"];
    r5_qty [shape=ellipse, label="数量", style=dashed, fillcolor=white];
    r5_price [shape=ellipse, label="单价", style=dashed, fillcolor=white];
    Ingredient -> R5 [label="1", len=0.3];
    R5 -> PurItem [label="n", len=0.3];
    R5 -> r5_qty [style=dashed, len=0.15];
    R5 -> r5_price [style=dashed, len=0.15];

    /* 食堂 ——验收——> 食材验收 */
    R6 [shape=diamond, label="验收", fillcolor="#e3f2fd"];
    r6_date [shape=ellipse, label="验收日期", style=dashed, fillcolor=white];
    Canteen -> R6 [label="1", len=0.3];
    R6 -> IngAccept [label="n", len=0.3];
    R6 -> r6_date [style=dashed, len=0.15];

    /* 食材 ——被验收——> 食材验收 */
    R7 [shape=diamond, label="被验收", fillcolor="#e3f2fd"];
    r7_qual [shape=ellipse, label="质量状态", style=dashed, fillcolor=white];
    Ingredient -> R7 [label="1", len=0.3];
    R7 -> IngAccept [label="n", len=0.3];
    R7 -> r7_qual [style=dashed, len=0.15];
}
